APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/agent_cv
PDF_ROOT=PDFs/REPOCV

AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

GRAPH_USER_EMAIL=
GRAPH_USER_PASSWORD=
TEAMS_BOT_APP_ID=
TEAMS_BOT_APP_PASSWORD=
TEAMS_BOT_TENANT_ID=

SHAREPOINT_URL=
SHAREPOINT_DRIVE_ID=          # Drive ID of the SharePoint library (GET /sites/{siteId}/drives or Graph Explorer)
SHAREPOINT_FOLDER_PATH=       # Option A: subfolder path within the drive root (e.g. "CV Repository")
SHAREPOINT_FOLDER_ITEM_ID=    # Option B: item ID of a specific folder — takes precedence over SHAREPOINT_FOLDER_PATH
SHAREPOINT_POLL_INTERVAL=     # seconds; default is 1 hour (3600)

APP_DOMAIN=agent-cv.example.com         # used by Traefik for routing + TLS cert
ACME_EMAIL=you@example.com              # Let's Encrypt notifications
WEBHOOK_BASE_URL=https://agent-cv.example.com
WEBHOOK_SECRET=<random-secret-string>   # generate with: python -c "import secrets; print(secrets.token_hex(32))"