# Azure Bot Service / Entra app registration
# Create at https://portal.azure.com → App registrations → New registration
# Then add a client secret under Certificates & secrets
BOT_APP_ID=
BOT_APP_PASSWORD=
# Entra tenant ID — required for single-tenant app registrations (set BOT_SKIP_AUTH=false)
BOT_TENANT_ID=

# Skip Bot Framework token validation.
# true  = local dev with DevToolsPlugin (no Azure Bot Service resource needed)
# false = production, requires a proper Azure Bot resource backing the app registration
BOT_SKIP_AUTH=true

# Teams app manifest template variables
# BOT_DOMAIN: public hostname where this bot is reachable (no https://)
#   - Local dev:  the DevToolsPlugin tunnel hostname, e.g. abc123.devtunnels.ms
#   - Production: your deployed hostname, e.g. agent-cv-teams.example.com
BOT_DOMAIN=
# TEAMS_APP_ID: a stable UUID that identifies this Teams app; generate once with:
#   python -c "import uuid; print(uuid.uuid4())"
TEAMS_APP_ID=
# DEVELOPER_NAME: shown in the Teams app store / app info card
DEVELOPER_NAME=My Organisation

# Backend connection
# URL of the Agent CV FastAPI backend /query endpoint
BACKEND_QUERY_URL=http://localhost:8000/query
BACKEND_TIMEOUT_SECONDS=20
# TLS verification for backend requests.
# true (default): verify TLS certificate normally
# false: disable verification (corporate proxy with self-signed CA)
# /path/to/ca-bundle.crt: trust a specific CA bundle
BACKEND_SSL_VERIFY=true
