{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.25/MicrosoftTeams.schema.json",
  "version": "1.0.0",
  "manifestVersion": "1.25",
  "id": "${{TEAMS_APP_ID}}",
  "name": {
    "short": "Agent CV",
    "full": "Agent CV — Certification Assistant"
  },
  "developer": {
    "name": "${{DEVELOPER_NAME}}",
    "mpnId": "",
    "websiteUrl": "https://microsoft.com",
    "privacyUrl": "https://privacy.microsoft.com/privacystatement",
    "termsOfUseUrl": "https://www.microsoft.com/legal/terms-of-use"
  },
  "description": {
    "short": "Search and explore team certifications and CVs.",
    "full": "Agent CV is a conversational AI assistant that lets you search, explore, and export certifications and professional profiles across your organisation. Ask questions like 'Who has Red Hat certifications?' or 'Show me expired AWS certs'."
  },
  "icons": {
    "outline": "outline.png",
    "color": "color.png"
  },
  "accentColor": "#FFFFFF",
  "staticTabs": [
    {
      "entityId": "conversations",
      "scopes": ["personal"]
    },
    {
      "entityId": "about",
      "scopes": ["personal"]
    }
  ],
  "bots": [
    {
      "botId": "${{BOT_APP_ID}}",
      "scopes": ["personal", "team", "groupChat"],
      "isNotificationOnly": false,
      "supportsCalling": false,
      "supportsVideo": false,
      "supportsFiles": false
    }
  ],
  "validDomains": [
    "${{BOT_DOMAIN}}",
    "*.botframework.com"
  ],
  "webApplicationInfo": {
    "id": "${{BOT_APP_ID}}",
    "resource": "api://botid-${{BOT_APP_ID}}"
  },
  "supportsChannelFeatures": "tier1"
}
